    },
    "cohort_observe": {
      "fromAddress": "observe@rhizoh.com",
      "fromName": "Rhizoh",
      "replyTo": "observe@rhizoh.com"
    }
  },
  "recipient": {
    "env": "SPIRALMMO_REPORT_TO",
