rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for published static artifacts under castle/.
    match /castle/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default deny.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
