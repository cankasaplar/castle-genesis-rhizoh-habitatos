{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rhizoh.local/schemas/rhizoh_event_envelope.schema.json",
  "title": "RhizohEventEnvelope",
  "type": "object",
  "additionalProperties": true,
  "required": ["type", "source", "schemaVersion", "correlationId", "actorUid"],
  "properties": {
    "type": { "type": "string", "minLength": 5, "maxLength": 200 },
    "source": { "type": "string", "enum": ["client", "gateway", "function", "witness", "system"] },
    "schemaVersion": { "type": "integer", "minimum": 1, "maximum": 100 },
    "correlationId": { "type": "string", "minLength": 5, "maxLength": 200 },
    "actorUid": { "type": "string", "minLength": 1 },
    "occurredAt": {},
    "castleId": { "type": "string" },
    "primaryClaimCount": { "type": "integer", "minimum": 0, "maximum": 2 }
  }
}
