rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for runtime maps/manifest-like docs.
    match /castle/{doc=**} {
      allow read: if true;
      // Writes must be authenticated; tighten further by role/claims in production.
      allow write: if request.auth != null;
    }

    // AppNext / vNext agent + command sync (see AppNext.jsx).
    match /artifacts/{appId}/public/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Kullanıcı profili + onboarding (CastleAuthOverlay / useCastleAuth).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny for everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
