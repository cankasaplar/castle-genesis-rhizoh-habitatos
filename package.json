{
  "name": "castle-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/client",
    "dev:client": "npm run dev -w apps/client",
    "dev:gateway": "npm run dev -w apps/gateway",
    "dev:sfu": "npm run dev -w apps/sfu",
    "dev:broadcaster": "npm run dev -w apps/broadcaster",
    "dev:orchestrator": "npm run dev -w apps/orchestrator",
    "dev:sim-core": "npm run dev -w apps/sim-core",
    "build": "npm run build -w apps/client",
    "firebase:build": "npm run build",
    "firebase:deploy": "npm run firebase:build && npx firebase-tools deploy",
    "firebase:deploy:hosting": "npm run firebase:build && npx firebase-tools deploy --only hosting",
    "firebase:deploy:hosting+firestore": "npm run firebase:build && npx firebase-tools deploy --only \"hosting,firestore:rules\"",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules,storage",
    "security:audit": "npm audit --audit-level=high",
    "security:sast": "node scripts/sast-check.js"
  }
}
