{
  "name": "castle-system",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/client",
    "dev:client": "npm run dev -w apps/client",
    "dev:gateway": "npm run dev -w apps/gateway",
    "dev:sfu": "npm run dev -w apps/sfu",
    "dev:broadcaster": "npm run dev -w apps/broadcaster",
    "dev:orchestrator": "npm run dev -w apps/orchestrator",
    "dev:sim-core": "npm run dev -w apps/sim-core",
    "dev:worker": "npm run dev -w apps/worker",
    "build": "npm run build -w apps/client",
    "test": "npm run test -w apps/client",
    "test:watch": "npm run test:watch -w apps/client",
    "firebase:build": "npm run build",
    "firebase:deploy": "npm run firebase:build && npx firebase-tools deploy",
    "firebase:deploy:hosting": "npm run firebase:build && npx firebase-tools deploy --only hosting",
    "firebase:deploy:hosting+firestore": "npm run firebase:build && npx firebase-tools deploy --only \"hosting,firestore:rules\"",
    "firebase:deploy:rules": "npx firebase-tools deploy --only firestore:rules,storage",
    "gateway:docker:build": "docker build -f apps/gateway/Dockerfile -t castle-gateway .",
    "security:audit": "npm audit --audit-level=high",
    "security:sast": "node scripts/sast-check.js",
    "validate:rhizoh-smoke": "node scripts/rhizoh-validation-smoke.mjs",
    "ci:schema-lock": "node scripts/verify-causal-schema-lock.mjs",
    "ci:read-stack": "npm run test -w apps/client -- src/studio/__tests__/studio-read-stack-integration.test.ts",
    "ci:enforce-client": "npm run ci:schema-lock && npm run typecheck -w apps/client && npm run test -w apps/client && npm run ci:read-stack",
    "verify:production": "node scripts/verify-production-env.mjs",
    "setup:env": "node scripts/setup-env-templates.mjs",
    "infra:replay": "npm run replay -w apps/worker",
    "stabilization:audit-chain": "node scripts/rhizoh-audit-chain-verify.mjs",
    "stabilization:validate-graph": "node scripts/validateStabilizationGraph.mjs",
    "stabilization:validate-specflow": "node scripts/validateSpecflowCoherence.mjs",
    "stabilization:validate-amendment": "node scripts/validateCilAmendment.mjs",
    "epistemic:ecg-binding-interpret": "node scripts/ecgBindingInterpreter.mjs",
    "epistemic:cee-template": "node scripts/ceeCompensationTemplate.mjs",
    "epistemic:cese-order": "node scripts/ceseRepairOrdering.mjs",
    "epistemic:gcr-reconcile": "node scripts/gcrReconcileReport.mjs",
    "epistemic:gemc-manifest": "node scripts/gemcConsolidationManifest.mjs",
    "epistemic:eqr-plan": "node scripts/eqrReconstructionPlan.mjs",
    "epistemic:csb-eval": "node scripts/evaluateBind.mjs",
    "epistemic:csb-harness": "node scripts/csbExecutionHarness.mjs",
    "epistemic:csb-vm": "node scripts/csbVmRecord.mjs",
    "epistemic:csb-vm-replay": "node scripts/csbVmReplay.mjs",
    "epistemic:mk1-validate": "node scripts/mk1Validate.mjs scripts/fixtures/mk1-sample-trace.mjs",
    "epistemic:mk1-stress": "node scripts/mk1StressHarness.mjs scripts/fixtures/mk1-stress-base.mjs",
    "epistemic:etk-verify": "node scripts/ecerEpistemicTransitionKernel.mjs",
    "epistemic:tta-verify": "node scripts/ecerTloaTransitionReport.mjs",
    "epistemic:hoga-verify": "node scripts/hogaComposition.mjs",
    "epistemic:ecer-smoke": "node scripts/ecerPipelineSmoke.mjs",
    "epistemic:ecer-adversarial": "node scripts/ecerAdversarialSuite.mjs",
    "epistemic:ecer-adv-check": "node scripts/ecerAdversarialMetaHarness.mjs check",
    "epistemic:ecer-adv-suggest": "node scripts/ecerAdversarialMetaHarness.mjs suggest",
    "stabilization:graph-hash": "node scripts/print-stabilization-graph-hash.mjs",
    "stabilization:replay": "npm run test -w apps/client -- src/rhizoh/constitution/__tests__/constitutionalReplayDeterminism.test.ts",
    "stabilization:load-test": "node scripts/rhizoh-load-test.mjs",
    "stabilization:distributed-check": "node scripts/rhizoh-distributed-consistency-check.mjs"
  }
}
