# COHORT_EMAIL_ALLOWLIST — cohortGateV0 için virgülle e-postalar (Gen2 function ortam değişkeni).
# Firebase Console → Functions → cohortGateV0 → yapılandırma VEYA:
#   firebase deploy --only functions --set-env-vars COHORT_EMAIL_ALLOWLIST="a@x.com,b@y.com"
# Boş bırakılırsa kapı 503 döner (fail-closed).

# Cohort session feedback mail (cohortSessionFeedbackMailV0, cohortFeedbackSubmitV0)
SPIRALMMO_SMTP_USER=
SPIRALMMO_SMTP_APP_PASSWORD=
RHIZOH_MAIL_COHORT_FROM=observe@rhizoh.com
RHIZOH_MAIL_COHORT_FROM_NAME=Rhizoh
RHIZOH_MAIL_COHORT_REPLY_TO=observe@rhizoh.com
SPIRALMMO_REPORT_TO=
RHIZOH_COHORT_OPS_TO=
