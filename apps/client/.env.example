# Castle Client — kopyala: cp .env.example .env.local
# Gerçek anahtarları repoya commit etmeyin.
#
# Firebase: ya VITE_FIREBASE_CONFIG (tek satır JSON) ya da VITE_FIREBASE_* alanları — vite.config birleştirir.

# RCIL Live Wiring Sprint — istemci `__RCIL_LIVE_WIRING__` dev hook (ingest / drain / snapshot / persist)
# Chunk async yüklenir: konsolda önce `await window.__RCIL_LIVE_WIRING_READY__` sonra `runPhase01`.
# VITE_RCIL_LIVE_WIRING=1
# Phase 0–1: `runPhase01` sonrası Firestore ledger yazımı (Firebase yapılandırılmış + rules)
# VITE_RCIL_LEDGER_WRITE=1

# Gateway WebSocket — VITE_GATEWAY_WS veya VITE_GATEWAY_WS_URL
VITE_GATEWAY_WS=ws://localhost:8090
VITE_GATEWAY_WS_URL=ws://localhost:8090

# Rhizoh LLM HTTP — VITE_GATEWAY_HTTP veya VITE_RHIZOH_LLM_HTTP
VITE_GATEWAY_HTTP=http://localhost:8090/rhizoh/llm
VITE_RHIZOH_LLM_HTTP=http://localhost:8090/rhizoh/llm

# Son kullanıcı akışı: boş bırakılırsa istemci varsayılan canlı gateway'e gider.
# Lokal gateway ile geliştirmek için:
# VITE_PREFER_LOCAL_GATEWAY=1
# VITE_LIVE_GATEWAY_BASE=https://castle-genesis-gateway.onrender.com
VITE_PREFER_LOCAL_GATEWAY=0
VITE_LIVE_GATEWAY_BASE=

# Gateway CASTLE_GATEWAY_TOKEN ile eşleşmeli (korunan uçlar + /rhizoh/epistemic/seal + /rhizoh/epistemic/logs/batch)
# Uzak hostta POST …/epistemic/seal veya …/logs/batch → 404: genelde eski gateway image; LLM 200 olsa bile apps/gateway güncel deploy + CASTLE_EPISTEMIC_SEAL_SECRET (veya token) gerekir.
VITE_GATEWAY_TOKEN=

# Stripe Checkout — istemci `startCastleStripeCheckout` / POST /billing/stripe/checkout kullanır; kart bilgisi Stripe’ta kalır.
# İsteğe bağlı (boşsa gateway .env STRIPE_CHECKOUT_* veya gövdedeki successUrl/cancelUrl):
# VITE_STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/account?checkout=success
# VITE_STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/account?checkout=cancel

# Ürün policy — dış ground truth (gateway nüfus kohortu GET /rhizoh/product/external-truth).
# Boşsa VITE_GATEWAY_HTTP kökünden URL türetilir. İstemci önbelleği: rhizoh.external_truth.bundle.cache.v1
# VITE_RHIZOH_EXTERNAL_TRUTH_HTTP=http://localhost:8090/rhizoh/product/external-truth
# Katı mod (paket yok/süresi geçmişse promote + merge blok): LS anahtarı rhizoh.policy.require_external_truth.v1 = "1"
# Kayıp proxy katmanı (72 saat): olaylar rhizoh.external_loss.events.v1 — güçlü ceza için promote blok: rhizoh.policy.block_promote_on_external_loss.v1 = "1"
# Ürün outcome / memnuniyet proxy / düzeltme — emit: emitRhizohProductSessionOutcome, emitRhizohProductSatisfactionProxy, emitRhizohProductCorrectionSignal
# Finalize merge freni (aynı eşik): rhizoh.policy.block_merge_on_external_loss.v1 = "1"
# İstikrar: 5 dk içinde en fazla 2 promote audit — rhizoh.policy.stability_budget_short_window.v1 = "1"
# Dış döngü asimetri tabanı (0.12–0.55, varsayılan 0.26): rhizoh.policy.external_asymmetry_floor.v1
# Dış döngü (truth/batch) gecikince iç öğrenmeyi düşürme; kapat: rhizoh.policy.disable_external_loop_asymmetry.v1 = "1"
# Dış kayıp → öğrenme çarpanı (varsayılan açık); tam adım için gradyanı kapat: rhizoh.policy.disable_external_loss_lr_gradient.v1 = "1"
# Batch ingest POST — boşsa gateway kökünden /rhizoh/product/external-loss/batch türetilir
# VITE_RHIZOH_EXTERNAL_LOSS_BATCH_HTTP=http://localhost:8090/rhizoh/product/external-loss/batch
# Kohort outcome özeti (GET /rhizoh/product/outcome/aggregate) — boşsa gateway kökünden türetilir. Önbellek: rhizoh.grounding.outcome_aggregates.cache.v1
# VITE_RHIZOH_OUTCOME_AGGREGATE_HTTP=http://localhost:8090/rhizoh/product/outcome/aggregate
# Gerçek dünya hizası: holdout kohortu için continuityMeta.analystStableKey | populationSubjectKey | firebaseUid (yoksa sessionId — tekil kullanıcı ≠ population)

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

VITE_RHIZOH_LLM_TOKEN=

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

# Tek satır JSON (alternatif: VITE_FIREBASE_API_KEY + VITE_FIREBASE_PROJECT_ID + …)
VITE_FIREBASE_CONFIG={}

VITE_CASTLE_APP_ID=castle-vnext-core

# vNext-541 — İstanbul habitat gerçek-zaman besleme (opsiyonel; boşsa ritim + Open-Meteo/USGS doğrudan)
# Trafik / etkinlik: JSON { "intensity": 0..1 } veya düz sayı gövdesi dönen kendi proxy URL’n
# VITE_ISTANBUL_FEED_TRAFFIC_HTTP=https://example.com/castle/istanbul/traffic
# VITE_ISTANBUL_FEED_EVENTS_HTTP=https://example.com/castle/istanbul/events
# Şebeke / altyapı sağlığı proxy: JSON { "gridHealth": 0..1 }
# VITE_ISTANBUL_FEED_GRID_HTTP=https://example.com/castle/istanbul/grid-health
