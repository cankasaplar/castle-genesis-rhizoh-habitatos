# Castle Client — kopyala: cp .env.example .env.local
# Gerçek anahtarları repoya commit etmeyin.
#
# PR-1 — Debug şemsiye: prod’da granular `VITE_RHIZOH_*_DEBUG` bayrakları için `VITE_DEBUG=1` gerekir (dev’de granular yeterli).
# VITE_DEBUG=1
#
# PR-1 — WORLD layer (Cesium / REAL_MAP / WebGL map stack): kapalı = survival / Genesis-first deploy.
# `0` | `false` | `off` → kapalı. Boş bırakılırsa varsayılan açık (geriye dönük).
# VITE_WORLD_LAYER=0
# veya: VITE_WORLD_LAYER=false
#
# Spatial shell (AppRhizoh528): WORLD layer açıkken Cesium tam ekran; metin paneli toggle (localStorage).
# Canlı atmosfer → Cesium köprüsü için:
# VITE_WORLD_EXECUTION_MODE=active
# VITE_CESIUM_ION_TOKEN=your_token
# Gateway (canlı bağlantı):
# VITE_GATEWAY_HTTP=http://localhost:8090/rhizoh/llm
# VITE_GATEWAY_WS=ws://localhost:8090
#
# PR-2 — WORLD execution: `off` | `passive` | `active`. Boşsa `VITE_WORLD_LAYER` ile hizalanır (layer kapalı → off).
# `passive` = OBSERVER (cache + provenance + ham türetim; smoothing/DOM/Cesium yok). `active` = EFFECTOR (tam yol).
# VITE_WORLD_EXECUTION_MODE=passive
#
# PR-2.5 — Observation envelope (replay / system lane): `sessionStorage` anahtarları (isteğe bağlı).
# `castle.observation.replay_lane.v1` = "1" → lane `replay` · `castle.replay_seed.v1` = deterministik replay tohumu (UTF-8).
# `castle.observation.system_lane.v1` = "1" → lane `system` (daemon / iç gözlem).
#
# Genesis Replay Observatory — v0.2.2-pre controlled opening (surface lock v0.1)
# `research` (default) = laboratory: metric topology may drift, adaptive UI.
# `observability` = live instrument: H_surface locked; mismatch → Legacy drift UI; passive epoch window (regime log-only).
# VITE_GENESIS_DEPLOY_MODE=research
# VITE_GENESIS_DEPLOY_MODE=observability
# First N epistemic gradient epochs: passive observability (regime shift → console log only; no control hooks).
# VITE_GENESIS_PASSIVE_EPOCH_MAX=100
# Dev QA: force Legacy drift UI in observability mode (H_surface mismatch simulation).
# VITE_GENESIS_SIMULATE_LEGACY_DRIFT=1
#
# Firebase: ya VITE_FIREBASE_CONFIG (tek satır JSON) ya da VITE_FIREBASE_* alanları — vite.config birleştirir.

# RCIL Live Wiring Sprint — istemci `__RCIL_LIVE_WIRING__` dev hook (ingest / drain / snapshot / persist)
# Chunk async yüklenir: konsolda önce `await window.__RCIL_LIVE_WIRING_READY__` sonra `runPhase01`.
# VITE_RCIL_LIVE_WIRING=1
# Phase 0–1: `runPhase01` sonrası Firestore ledger yazımı (Firebase yapılandırılmış + rules)
# VITE_RCIL_LEDGER_WRITE=1
#
# RDVH: tarayıcıda canlı trace aynası (son 256 satır) — `__RCIL_LIVE_WIRING__.subscribeRdvhTrace(cb)` ile de abone olunur
# VITE_RDVH_TRACE_STREAM=1
# Yüksek hacimli runPressureLoop: dev konsolda uyarı → `rdvPressureAck: true`; parmak izi/export gürültüsü için `semantics: operational_only` / `continuitySemantics: operational_only`
# Replay snapshot hydrate (export → başka oturum) — yalnız güvenilir dev ortamında; testlerde MODE=test ile zaten açık
# VITE_RCIL_REPLAY_HYDRATE=1
#
# Sprint C — always-on world runtime daemon (stream queue, reconciliation, convergence tick; NOT rAF)
# VITE_WORLD_RUNTIME_DAEMON=1
# Sprint C.1 — gateway WS peer WAL convergence (quarantine / accept); needs VITE_GATEWAY_WS + daemon recommended
# VITE_PEER_WAL_CONVERGENCE=1
# Optional: force 4s dedicated WAL publish when natural social traffic is stale (default: auto-fallback only)
# VITE_PEER_WAL_PUBLISH_FALLBACK=1
#
# Sprint B — WAL geometry ingress: gateway mesh / viewport scene → seal candidates (never direct realityEpoch)
# VITE_WAL_GEOMETRY_INGRESS=1
# Reality sealer: localStorage persist + optional heartbeat poke (sealer-only epoch advance)
# VITE_REALITY_SEAL_PERSIST=1
# VITE_REALITY_SEAL_HEARTBEAT=1
#
# RRHP Persistent Projection v1 — `users/{uid}/rrhp_projection_v1/singleton` merge-only (auth gerekir)
# VITE_RRHP_PERSIST=1
# Cold session restore (Firestore → bellek projection); persist ile birlikte
# VITE_RRHP_HYDRATE=1
#
# Continuity: probe JSON → Markdown rapor (CI / arşiv) — repo kökü: npm run continuity:probe-report -- path/to/probe-snapshot.json

# Gateway WebSocket — VITE_GATEWAY_WS veya VITE_GATEWAY_WS_URL
VITE_GATEWAY_WS=ws://localhost:8090
VITE_GATEWAY_WS_URL=ws://localhost:8090

# Rhizoh LLM HTTP — VITE_GATEWAY_HTTP veya VITE_RHIZOH_LLM_HTTP
VITE_GATEWAY_HTTP=http://localhost:8090/rhizoh/llm
VITE_RHIZOH_LLM_HTTP=http://localhost:8090/rhizoh/llm

# Son kullanıcı akışı: boş bırakılırsa istemci varsayılan canlı gateway köküne gider (castleFlightConfig.js).
# Üretimde: VITE_LIVE_GATEWAY_BASE kökü, VITE_GATEWAY_HTTP origin’i ile aynı olmalı (Genesis SSE + LLM tek gateway).
# Lokal gateway ile geliştirmek için:
# VITE_PREFER_LOCAL_GATEWAY=1
# VITE_LIVE_GATEWAY_BASE=https://YOUR-RENDER-HOST.onrender.com
VITE_PREFER_LOCAL_GATEWAY=0
VITE_LIVE_GATEWAY_BASE=

# Gateway CASTLE_GATEWAY_TOKEN ile eşleşmeli (korunan uçlar + /rhizoh/epistemic/seal + /rhizoh/epistemic/logs/batch)
# Uzak hostta POST …/epistemic/seal veya …/logs/batch → 404: genelde eski gateway image; LLM 200 olsa bile apps/gateway güncel deploy + CASTLE_EPISTEMIC_SEAL_SECRET (veya token) gerekir.
VITE_GATEWAY_TOKEN=

# --- World presence / atmospheric (STEP B) — OpenWeather (isteğe bağlı; boşsa nötr ambient) ---
# https://openweathermap.org/api — istemci tarafı anahtar: yalnız dev / sınırlı kota; prod’da proxy tercih edilir.
# VITE_OPENWEATHER_API_KEY=
# Varsayılan: İstanbul merkez yaklaşımı (lat,lon)
# VITE_OPENWEATHER_LAT=41.015137
# VITE_OPENWEATHER_LON=28.979530
# Atmosferik projection debug şeridi (WEATHER / VISIBILITY / AURA / FOG) — yalnız dev
# VITE_RHIZOH_ATMOSPHERE_DEBUG=1
#
# Rhizoh Shadow Witness v0 — §14 authority decision points → console.debug (yalnız `castleDebugGateV0` açıkken)
# VITE_RHIZOH_AUTHORITY_WITNESS_DEBUG=1
#
# Voice Engine v3 — hybrid ASR (MediaRecorder → gateway Google fast + Whisper accurate). Chrome STT = optional trigger only.
# VITE_RHIZOH_VOICE_ENGINE_V3=1
# Conversation dock (spatial shell): text always; mic when v3=1
# VITE_RHIZOH_VOICE_ENGINE_V3_CHROME_TRIGGER=1
#
# Influence attribution (Phase 1 — core + logging; read-only hooks on v3 bridge; no memory coupling):
#   window.__rhizoh.voiceInfluenceAttribution  { last, counts, recent, influenceStrength }
# Attention context (RESEARCH-ONLY v0 — life channel; does not change gates):
#   VITE_RHIZOH_VOICE_ATTENTION_MODE=direct_listen|moving_context|observer
# Relationship kernel V0 (friend not coach — shared awareness; observation only):
#   VITE_RHIZOH_SHARED_ATTENTION_TYPE=co_presence|exploratory|silence_aware|shared_focus
#   window.__rhizoh.relationshipKernel · setSharedAttentionType('co_presence')
#   pressureDynamics (session) · mutualFamiliarityField (habit ring, localStorage observation only)
# Phase 2 (staged): witness pipeline → voiceInfluenceAttributionPipelineHookV0 (castle-t0-interface first)
# Observational cognition (RESEARCH-ONLY — shadow path, no auto-threshold):
# VITE_RHIZOH_VOICE_WITNESS_SHADOW=1
# Faz 3 directed tur (kapalı tutun; shadow metrikleri önce): VITE_RHIZOH_DIRECTED_SPEECH_GATE=1
# VITE_RHIZOH_VOICE_SHADOW_OBS_ACK=1
# copy(window.__rhizoh.exportShadowVoiceAnalysisV0()) · window.__rhizoh.shadowReplaySignals
# Temporal cognition: window.__rhizoh.voiceShadowTimeline (default 5s buckets)
# VITE_RHIZOH_VOICE_TIMELINE_BUCKET_MS=5000
# Map: apps/client/docs/RHIZOH_VOICE_OBSERVATIONAL_COGNITION_MAP_V0.md

# Stripe Checkout — istemci `startCastleStripeCheckout` / POST /billing/stripe/checkout kullanır; kart bilgisi Stripe’ta kalır.
# İsteğe bağlı (boşsa gateway .env STRIPE_CHECKOUT_* veya gövdedeki successUrl/cancelUrl):
# VITE_STRIPE_CHECKOUT_SUCCESS_URL=http://localhost:5173/account?checkout=success
# VITE_STRIPE_CHECKOUT_CANCEL_URL=http://localhost:5173/account?checkout=cancel

# Ürün policy — dış ground truth (gateway nüfus kohortu GET /rhizoh/product/external-truth).
# Boşsa VITE_GATEWAY_HTTP kökünden URL türetilir. İstemci önbelleği: rhizoh.external_truth.bundle.cache.v1
# VITE_RHIZOH_EXTERNAL_TRUTH_HTTP=http://localhost:8090/rhizoh/product/external-truth
# Katı mod (paket yok/süresi geçmişse promote + merge blok): LS anahtarı rhizoh.policy.require_external_truth.v1 = "1"
# Kayıp proxy katmanı (72 saat): olaylar rhizoh.external_loss.events.v1 — güçlü ceza için promote blok: rhizoh.policy.block_promote_on_external_loss.v1 = "1"
# Ürün outcome / memnuniyet proxy / düzeltme — emit: emitRhizohProductSessionOutcome, emitRhizohProductSatisfactionProxy, emitRhizohProductCorrectionSignal
# Finalize merge freni (aynı eşik): rhizoh.policy.block_merge_on_external_loss.v1 = "1"
# İstikrar: 5 dk içinde en fazla 2 promote audit — rhizoh.policy.stability_budget_short_window.v1 = "1"
# Dış döngü asimetri tabanı (0.12–0.55, varsayılan 0.26): rhizoh.policy.external_asymmetry_floor.v1
# Dış döngü (truth/batch) gecikince iç öğrenmeyi düşürme; kapat: rhizoh.policy.disable_external_loop_asymmetry.v1 = "1"
# Dış kayıp → öğrenme çarpanı (varsayılan açık); tam adım için gradyanı kapat: rhizoh.policy.disable_external_loss_lr_gradient.v1 = "1"
# Batch ingest POST — boşsa gateway kökünden /rhizoh/product/external-loss/batch türetilir
# VITE_RHIZOH_EXTERNAL_LOSS_BATCH_HTTP=http://localhost:8090/rhizoh/product/external-loss/batch
# Kohort outcome özeti (GET /rhizoh/product/outcome/aggregate) — boşsa gateway kökünden türetilir. Önbellek: rhizoh.grounding.outcome_aggregates.cache.v1
# VITE_RHIZOH_OUTCOME_AGGREGATE_HTTP=http://localhost:8090/rhizoh/product/outcome/aggregate
# Gerçek dünya hizası: holdout kohortu için continuityMeta.analystStableKey | populationSubjectKey | firebaseUid (yoksa sessionId — tekil kullanıcı ≠ population)

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

# Rhizoh B1 — REAL_MAP: ilk kamera Sarıyer (kalibrasyon kökü), terrain sonrası fog/globe + tek root entity (Cesium truth değil; projection substrate)
# VITE_RHIZOH_EPISTEMIC_CESIUM_BOOTSTRAP=1
# Epistemik origin/mode → `window.__CASTLE_CESIUM__` yalnızca konsol aynası (store SSOT: cesiumEpistemicRuntimeStoreV0)
# VITE_RHIZOH_EPISTEMIC_RUNTIME_DEBUG=1
# B3 — canlı orchestrator tick (ms, 500–600000); boşsa 4000
# VITE_RHIZOH_LIVE_ORCHESTRATOR_TICK_MS=4000
# UI / etkileşim kilidi (abonelik veya harici güvenlik değil). 0 veya false → INTERACT kapalı
# VITE_RHIZOH_INTERACT_ENABLED=1

# Ingress / activation (SSOT: phase1ActivationGateV0.js) — checklist before setting 1
# VITE_RHIZOH_LEGAL_PREAMBLE=1
# VITE_RHIZOH_CLOSED_ADMISSION=0
# VITE_RHIZOH_PHASE1_SIGNAL=0
#
# Kapalı kohort (deploy): Google-only shell + isteğe bağlı e-posta allowlist (virgülle ayırın, küçük harf normalize)
# VITE_RHIZOH_INVITE_ONLY_GOOGLE=1
# VITE_RHIZOH_COHORT_EMAIL_ALLOWLIST=alice@example.com,bob@example.com
# Sunucu kökü kohort kapısı (önerilen üretim): istemci allowlist yetki için devre dışı kalır.
# VITE_RHIZOH_COHORT_SERVER_GATE=1
# İsteğe bağlı tam URL; boşsa aynı origin /api/cohortGateV0 (Firebase Hosting rewrite + Functions deploy gerekir)
# VITE_RHIZOH_COHORT_GATE_URL=https://castle-genesis.web.app/api/cohortGateV0
# Gözlem halkası: `0` kapalı | `1` zorunlu açık | boş = invite-only veya allowlist açıksa otomatik açık
# VITE_RHIZOH_COHORT_OBSERVATION_LOG=1
#
# Ontological boot gate — `1` = IDB living world seal zorunlu (quarantine mümkün). Boş veya `0` = kapalı (kohort cold start).
# VITE_ONTOLOGICAL_BOOT_GATE=0

VITE_RHIZOH_LLM_TOKEN=

# Cross-Layer Awareness Graph (CLAG) — observability default on via living world + LLM bridge
# VITE_RHIZOH_CLAG_MEMORY_SHAPING=0
# Bounded emergence allocator (observability only): resonance budget 0..1
# VITE_RHIZOH_BEA_RESONANCE_BUDGET=0.15
# Runtime stability — prod uses conversationBehavior only; 1 = expose internal CLAG on window (dev)
# VITE_RHIZOH_STABILITY_VERBOSE=0
# Fast Speech Mode — speech-first hot path; CLAG async (default on). Set 0 for legacy sync pipeline.
# VITE_RHIZOH_FAST_SPEECH_MODE=1
# Conversation behavior mirror (measurement only, no learning): on by default; set 0 to disable
# VITE_RHIZOH_CONVERSATION_MIRROR=1
# Mirror inspect strip (DEV / ?mirror=1 / explicit UI flag): VITE_RHIZOH_CONVERSATION_MIRROR_UI=1
# Influence bundle verbose ticks (dev): VITE_RHIZOH_INFLUENCE_VERBOSE=1
# Influence → cognition feedback (experimental, off): VITE_RHIZOH_INFLUENCE_FEEDBACK=0

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

# Tek satır JSON (alternatif: VITE_FIREBASE_API_KEY + VITE_FIREBASE_PROJECT_ID + …)
VITE_FIREBASE_CONFIG={}

VITE_CASTLE_APP_ID=castle-vnext-core

# vNext-541 — İstanbul habitat gerçek-zaman besleme (opsiyonel; boşsa ritim + Open-Meteo/USGS doğrudan)
# Trafik / etkinlik: JSON { "intensity": 0..1 } veya düz sayı gövdesi dönen kendi proxy URL’n
# VITE_ISTANBUL_FEED_TRAFFIC_HTTP=https://example.com/castle/istanbul/traffic
# VITE_ISTANBUL_FEED_EVENTS_HTTP=https://example.com/castle/istanbul/events
# Şebeke / altyapı sağlığı proxy: JSON { "gridHealth": 0..1 }
# VITE_ISTANBUL_FEED_GRID_HTTP=https://example.com/castle/istanbul/grid-health
