# Castle Client — kopyala: cp .env.example .env.local
# Gerçek anahtarları repoya commit etmeyin.
#
# UYUM: VITE_GATEWAY_TOKEN değeri, gateway tarafındaki CASTLE_GATEWAY_TOKEN ile aynı olmalıdır.
#       Firebase: ENV_KEYS.md ve VITE_FIREBASE_CONFIG (Console Web app JSON, tek satır).

# Gateway WebSocket (üretimde wss:// kullanın)
VITE_GATEWAY_WS_URL=ws://localhost:8090
# Gateway CASTLE_GATEWAY_TOKEN ile eşleşmeli
VITE_GATEWAY_TOKEN=

# İHA telemetri köprüsü (MAVLink→JSON veya ROS bridge WebSocket)
VITE_DRONE_TELEMETRY_WS=

# HTTP replay / viewer API tabanı (opsiyonel)
VITE_FLIGHT_VIEWER_HTTP=

# Harita: Cesium Ion (önerilir) veya Mapbox / özel karo şablonu
VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

# Rhizoh LLM — gateway HTTP endpointi (yerel varsayılan aşağıda)
VITE_RHIZOH_LLM_HTTP=http://localhost:8090/rhizoh/llm
VITE_RHIZOH_LLM_TOKEN=

# Telemetri ve simülasyon
VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

# Firebase Web SDK — tek satır JSON (apiKey, authDomain, projectId, appId, …)
VITE_FIREBASE_CONFIG={}

# AppNext Firestore kökü: artifacts/{VITE_CASTLE_APP_ID}/public/...
VITE_CASTLE_APP_ID=castle-vnext-core

# Üretim şablonu: apps/client/.env.production.example
