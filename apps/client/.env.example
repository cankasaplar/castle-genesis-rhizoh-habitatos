# Castle Client — kopyala: cp .env.example .env.local
# Gerçek anahtarları repoya commit etmeyin.
#
# Firebase: ya VITE_FIREBASE_CONFIG (tek satır JSON) ya da VITE_FIREBASE_* alanları — vite.config birleştirir.

# Gateway WebSocket — VITE_GATEWAY_WS veya VITE_GATEWAY_WS_URL
VITE_GATEWAY_WS=ws://localhost:8090
VITE_GATEWAY_WS_URL=ws://localhost:8090

# Rhizoh LLM HTTP — VITE_GATEWAY_HTTP veya VITE_RHIZOH_LLM_HTTP
VITE_GATEWAY_HTTP=http://localhost:8090/rhizoh/llm
VITE_RHIZOH_LLM_HTTP=http://localhost:8090/rhizoh/llm

# Gateway CASTLE_GATEWAY_TOKEN ile eşleşmeli
VITE_GATEWAY_TOKEN=

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

VITE_RHIZOH_LLM_TOKEN=

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

# Tek satır JSON (alternatif: VITE_FIREBASE_API_KEY + VITE_FIREBASE_PROJECT_ID + …)
VITE_FIREBASE_CONFIG={}

VITE_CASTLE_APP_ID=castle-vnext-core
