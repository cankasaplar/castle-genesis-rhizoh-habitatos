# T0 full interface — production deploy template (rhizoh.com)
# Copy to .env.production when deploying deploy_track=t0-interface-lock
# Lock SSOT: docs/ops/T0_INTERFACE_LOCK_V1.0.md · commit 8bd4ff9

# Firebase — same as .env.production.example
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=castle-genesis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=castle-genesis
VITE_FIREBASE_STORAGE_BUCKET=castle-genesis.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# T0 monolith — full spatial + swarm (not genesis text shell)
VITE_WORLD_LAYER=1
VITE_WORLD_EXECUTION_MODE=active

# Gateway — single origin (Render)
VITE_RHIZOH_LLM_HTTP=https://YOUR-RENDER-HOST.onrender.com/rhizoh/llm
VITE_GATEWAY_HTTP=https://YOUR-RENDER-HOST.onrender.com/rhizoh/llm
VITE_GATEWAY_WS=wss://YOUR-RENDER-HOST.onrender.com
VITE_LIVE_GATEWAY_BASE=https://YOUR-RENDER-HOST.onrender.com
VITE_GATEWAY_TOKEN=

VITE_CESIUM_ION_TOKEN=
VITE_CASTLE_APP_ID=castle-vnext-core
VITE_CASTLE_AUTHORITY_PROFILE=production

# Product posture — full UI without research overlay leak
VITE_DEBUG=0
VITE_SATELLITE_NODE_REGISTRY_V0=0
VITE_SOVEREIGN_NODE_ONBOARDING=0
VITE_EPISTEMIC_SIM_RESEARCH=0
VITE_ONTOLOGICAL_BOOT_GATE=0

# Cohort / ingress (rhizoh.com)
VITE_RHIZOH_INVITE_ONLY_GOOGLE=1
# VITE_RHIZOH_COHORT_EMAIL_ALLOWLIST= (GitHub secret)
# VITE_RHIZOH_COHORT_SERVER_GATE=1
