# Production — kopyala: .env.production
# Firebase Hosting: https://castle-genesis.web.app
#
# Firebase — ya tek satır JSON ya da aşağıdaki public alanlar (ikisi birden olabilir; öncelik tek satırda).
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...", ...}

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=castle-genesis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=castle-genesis
VITE_FIREBASE_STORAGE_BUCKET=castle-genesis.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# İsteğe bağlı
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_DATABASE_URL=https://castle-genesis-default-rtdb.firebaseio.com

# Gateway — Render Castle gateway (Node apps/gateway); tam path /rhizoh/llm
# MVP freeze: aşağıdaki üçlü (HTTP×2 + WS) kesin doldur; VITE_GATEWAY_URL tek başına omurga sayılmaz.
# Build sırasında gömülür; boş kalırsa tarayıcı "demo" moduna düşer.
# CASTLE_GATEWAY_TOKEN (Render) = bu dosyadaki VITE_GATEWAY_TOKEN ile aynı olmalı.
#
# Render: bu monorepo (kök render.yaml veya docs/RENDER_GATEWAY.md). YOUR-RENDER-SUBDOMAIN yerine paneldeki host (örn. castle-genesis-gateway).
# Health: https://YOUR-RENDER-SUBDOMAIN.onrender.com/health/live | .../ready | .../deps
VITE_RHIZOH_LLM_HTTP=https://YOUR-RENDER-SUBDOMAIN.onrender.com/rhizoh/llm
VITE_GATEWAY_HTTP=https://YOUR-RENDER-SUBDOMAIN.onrender.com/rhizoh/llm
VITE_GATEWAY_WS=wss://YOUR-RENDER-SUBDOMAIN.onrender.com
VITE_GATEWAY_TOKEN=castle_dev_token_2026

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

VITE_RHIZOH_LLM_TOKEN=

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

VITE_CASTLE_APP_ID=castle-vnext-core

# İsteğe bağlı — bilgi amaçlı (import.meta.env.MODE üretimde zaten production)
# VITE_ENV=production
