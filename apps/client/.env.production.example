# Production — kopyala: .env.production
# HTTPS sitede VITE_GATEWAY_WS_URL=wss://... ve public gateway host kullanın.
#
# Token uyumu: VITE_GATEWAY_TOKEN === gateway CASTLE_GATEWAY_TOKEN

VITE_GATEWAY_WS_URL=wss://your-api.example/ws
VITE_GATEWAY_TOKEN=

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

VITE_RHIZOH_LLM_HTTP=https://your-api.example/rhizoh/llm
VITE_RHIZOH_LLM_TOKEN=

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

# Firebase Console → Web app config (tek satır). projectId: castle-genesis
VITE_FIREBASE_CONFIG={"apiKey":"","authDomain":"castle-genesis.firebaseapp.com","databaseURL":"https://castle-genesis-default-rtdb.firebaseio.com","projectId":"castle-genesis","storageBucket":"","messagingSenderId":"","appId":"","measurementId":""}

VITE_CASTLE_APP_ID=castle-vnext-core
