# Production — kopyala: .env.production
# Firebase Hosting: https://castle-genesis.web.app
#
# Firebase — ya tek satır JSON ya da aşağıdaki public alanlar (ikisi birden olabilir; öncelik tek satırda).
# VITE_FIREBASE_CONFIG={"apiKey":"...","authDomain":"...","projectId":"...", ...}

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=castle-genesis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=castle-genesis
VITE_FIREBASE_STORAGE_BUCKET=castle-genesis.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# İsteğe bağlı
# VITE_FIREBASE_MEASUREMENT_ID=
# VITE_FIREBASE_DATABASE_URL=https://castle-genesis-default-rtdb.firebaseio.com

# Genesis-first / survival deploy: Cesium / REAL_MAP stack kapalı (`0` | `false` | `off`).
# VITE_WORLD_LAYER=false

# Gateway — Render Castle gateway (Node apps/gateway); tam path /rhizoh/llm
# MVP freeze: LLM HTTP + WS + live base + token build’e gömülmeli; VITE_GATEWAY_URL tek başına omurga sayılmaz.
# Build sırasında gömülür; boş kalırsa tarayıcı "demo" moduna düşer.
# CASTLE_GATEWAY_TOKEN (Render) = bu dosyadaki VITE_GATEWAY_TOKEN ile aynı olmalı.
#
# Tek truth: LLM + WS + VITE_LIVE_GATEWAY_BASE aynı Render host (aynı origin). İki farklı gateway URL’si → runtime vs Genesis SSE drift.
# Render panelindeki tam HTTPS kökü kullan (örn. castle-genesis-rhizoh-habitatos.onrender.com).
# Health: https://YOUR-RENDER-HOST.onrender.com/health/live | .../ready | .../deps
VITE_RHIZOH_LLM_HTTP=https://YOUR-RENDER-HOST.onrender.com/rhizoh/llm
VITE_GATEWAY_HTTP=https://YOUR-RENDER-HOST.onrender.com/rhizoh/llm
VITE_GATEWAY_WS=wss://YOUR-RENDER-HOST.onrender.com
# Genesis fallback / barındırma aynı origin — VITE_GATEWAY_HTTP ile aynı host olmalı (path yok, sondaki / yok)
VITE_LIVE_GATEWAY_BASE=https://YOUR-RENDER-HOST.onrender.com
VITE_GATEWAY_TOKEN=castle_dev_token_2026

VITE_DRONE_TELEMETRY_WS=
VITE_FLIGHT_VIEWER_HTTP=

VITE_SATELLITE_TILE_TEMPLATE=
VITE_MAPBOX_TOKEN=
VITE_CESIUM_ION_TOKEN=

VITE_RHIZOH_LLM_TOKEN=

VITE_TELEMETRY_MAX_HZ=30
VITE_SIM_DRONE_COUNT=4

VITE_CASTLE_APP_ID=castle-vnext-core

# Ontological authority profile (not just API host): production = strict seal + unsigned WAL reject.
VITE_CASTLE_AUTHORITY_PROFILE=production

# Ontological boot gate — `1` = seal path açık. Boş/`0` = kapalı (varsayılan kohort).
VITE_ONTOLOGICAL_BOOT_GATE=0

# --- Rhizoh Go-Live Activation Protocol V1 (docs/RHIZOH_GO_LIVE_ACTIVATION_PROTOCOL_V1.md) ---
VITE_DEBUG=0
VITE_ONTOLOGICAL_WATCHDOG=1
VITE_SOVEREIGN_NODE_ONBOARDING=1
VITE_SATELLITE_NODE_REGISTRY_V0=1
VITE_EPISTEMIC_SIM_RESEARCH=0
# VITE_REAL_LAYER_WEATHER_INGRESS=1
# VITE_REAL_LAYER_TRAFFIC_INGRESS=1
# VITE_OPENWEATHER_API_KEY=
# VITE_API_TIMEOUT_MS=2500
# VITE_MAX_CONCURRENT_NODES_BOOTSTRAP=128

# Substrate stack (enable when deploying sealed-reality ingress)
# VITE_WAL_GEOMETRY_INGRESS=1
# VITE_WORLD_RUNTIME_DAEMON=1
# VITE_PEER_WAL_CONVERGENCE=1
# VITE_REALITY_SEAL_PERSIST=1
# VITE_REALITY_SEAL_HEARTBEAT=1
# Post-deploy operational signal → gateway /rhizoh/substrate/health (Prometheus via /infra/metrics)
# VITE_SUBSTRATE_HEALTH_REPORT=1

# İsteğe bağlı — bilgi amaçlı (import.meta.env.MODE üretimde zaten production)
# VITE_ENV=production
