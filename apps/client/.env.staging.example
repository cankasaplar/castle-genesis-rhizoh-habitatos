# Staging — permissive quarantine thresholds, still rejects unsigned WAL at client profile.
# Copy: cp .env.staging.example .env.staging

VITE_CASTLE_AUTHORITY_PROFILE=staging

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=castle-genesis.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=castle-genesis
VITE_FIREBASE_STORAGE_BUCKET=castle-genesis.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_GATEWAY_HTTP=https://YOUR-STAGING-GATEWAY/rhizoh/llm
VITE_GATEWAY_WS=wss://YOUR-STAGING-GATEWAY
VITE_LIVE_GATEWAY_BASE=https://YOUR-STAGING-GATEWAY
VITE_GATEWAY_TOKEN=

VITE_WAL_GEOMETRY_INGRESS=1
VITE_WORLD_RUNTIME_DAEMON=1
VITE_PEER_WAL_CONVERGENCE=1
VITE_SUBSTRATE_HEALTH_REPORT=1
VITE_REALITY_SEAL_PERSIST=0
VITE_REALITY_SEAL_HEARTBEAT=0
# Faz 2.0 continuity harness (per-drain IDB + cold hydrate proof)
VITE_SUBSTRATE_CONTINUITY_IDB=0
