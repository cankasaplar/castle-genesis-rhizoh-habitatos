# Gateway — kopyala: cp .env.example .env
# Üretim sunucusu için tam şablon: apps/gateway/.env.production.example
# (veya .env.local; sunucu başlarken önce .env, sonra .env.local yüklenir — .env.local önceliklidir)
# Üretimde gerçek değerleri barındırıcı ortam değişkenlerinde tutun.

# --- Ağ ve güvenlik ---
CASTLE_GATEWAY_PORT=8090
CASTLE_MAX_MESSAGE_BYTES=32768
# İstemci VITE_GATEWAY_TOKEN ile AYNI gizli dize olmalı
CASTLE_GATEWAY_TOKEN=
# Epistemik mühür (/rhizoh/epistemic/seal) — imza için ayrı gizli önerilir; boşsa CASTLE_GATEWAY_TOKEN kullanılır
CASTLE_EPISTEMIC_SEAL_SECRET=
# CASTLE_RL_EPISTEMIC_SEAL_PER_MIN=120
# İstemci batch ledger ingest (/rhizoh/epistemic/logs/batch)
# CASTLE_RL_EPISTEMIC_LOG_PER_MIN=240
# Forecast integrity EMA alpha (internal-only calibration)
# CASTLE_FORECAST_EMA_ALPHA=0.22
# (optional) self-tuning başlangıç eşikleri internal; kod içi defaultlarla çalışır
# Uzun pencere attractor drift analizi (gateway internal)
# CASTLE_ATTRACTOR_LONG_WINDOW=96
# Orta pencere cross-scale coupling analizi (gateway internal)
# CASTLE_ATTRACTOR_MESO_WINDOW=36
# Epistemik self-consistency solver (internal-only; residual minimization loop)
# CASTLE_EPISTEMIC_SOLVER_ETA=0.14
# CASTLE_EPISTEMIC_SOLVER_INNER_STEPS=3
# Epistemik faz manifoldu üzerinde ayrık jeodezik / eğrilik penceresi (gateway internal)
# CASTLE_EPISTEMIC_GEODESIC_HISTORY=8
CASTLE_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173
# Üretim KRİTİK: listeyi ve CASTLE_HTTP_CORS_ORIGIN’i doldur; boşsa tarayıcıda SSE/replay “offline” (CORS).
# CASTLE_ALLOWED_ORIGINS=https://castle-genesis.web.app,https://castle-genesis.firebaseapp.com
# CASTLE_HTTP_CORS_ORIGIN=https://castle-genesis.web.app
CASTLE_HTTP_CORS_ORIGIN=http://localhost:5173
# Genesis continuity disk (checkpoint JSONL + continuity head). Sunucu boş bırakılırsa 1 kabul edilir; kapatmak için açıkça 0.
# CASTLE_GENESIS_DISK_PERSIST=1
# CASTLE_GENESIS_DISK_PERSIST=0
# CASTLE_GENESIS_DATA_DIR=/var/lib/castle-genesis
# Checkpoint query (read-only): explicit 0 → 410 genesis_ephemeral_mode; unset veya ≠1 → 503; =1 → durable projection.
# GET /rhizoh/genesis/checkpoint/by-seq/<seq>
# GET /rhizoh/genesis/checkpoint/range?from=&to=
# GET /rhizoh/genesis/checkpoint/lineage?seq=
# Opsiyonel: her continuity event için JSONL arşivi (ctx=1 dışı kalıcı bant; disk + bayrak)
# CASTLE_GENESIS_EVENT_ARCHIVE=1
# Birleşik replay (ring → archive dedup + checkpoint bandı): GET /rhizoh/genesis/replay?from=&to= veya range=from-to
# Temporal diff: GET /rhizoh/genesis/replay/diff?from=&to=
# Equivalence (two bands, same fingerprint manifold): GET /rhizoh/genesis/replay/equivalence?from1=&to1=&from2=&to2=
# Analytics (topology + ∇H field): GET /rhizoh/genesis/replay/analytics?from=&to=&bins=16
# Evolution (phase + collapse + curvature): GET /rhizoh/genesis/replay/evolution?from=&to=&bins=16&collapseWindows=0
# Read-only observatory freeze marker (boot log once when =1): GENESIS OBSERVATORY LIVE v0.1 — READ ONLY PHASE STARTED
# CASTLE_GENESIS_OBSERVATORY_LIVE_V01=1
CASTLE_REQUIRE_AUTH=false
# Üretim KRİTİK: true iken istemci gateway token göndermezse sessiz 401; EventSource özel header taşıyamaz (proxy gerekir).
# CASTLE_REQUIRE_AUTH=true
# Üretim KRİTİK: açık bırakma — auth bypass / farklı kimlik yüzeyi; prod’da false yap.
CASTLE_ALLOW_DEV_ANON=true
CASTLE_ALLOW_DEV_HTTP_UID=true
# Firebase Admin yokken JWT ile doğrulama: güçlü rastgele dize
CASTLE_JWT_SECRET=

# --- Stripe (üyelik: Checkout + webhook; kart verisi yalnızca Stripe’ta) ---
# Webhook: POST /webhooks/stripe — ham gövde imzası zorunlu
STRIPE_WEBHOOK_SECRET=
# Checkout oturumu: POST /billing/stripe/checkout (Authorization: Bearer <Firebase ID token>)
STRIPE_SECRET_KEY=
# Abonelik fiyatı (Price ID); istek gövdesinde priceId ile ezilebilir
STRIPE_PREMIUM_PRICE_ID=
# İsteğe bağlı: birden fazla premium fiyat (virgülle)
# STRIPE_PREMIUM_PRICE_IDS=price_a,price_b
# STRIPE_CHECKOUT_SUCCESS_URL=https://example.com/account?checkout=success
# STRIPE_CHECKOUT_CANCEL_URL=https://example.com/account?checkout=cancel
# Webhook olay tekrarı — LRU (tek süreç). Yaş tavanı 0 = kapalı (Stripe yeniden denemeleri için dikkatli açın)
# CASTLE_STRIPE_REPLAY_CACHE_MAX=8000
# CASTLE_STRIPE_WEBHOOK_MAX_EVENT_AGE_SEC=0

# vNext-Edge Reality Consistency — GET /health/reality (drift + fingerprint + parity)
# CI: npm run reality:lock-hash -w @castle/gateway ile SHA256 üret; deploy’da aynı değer beklenir
# CASTLE_REALITY_CONTRACT_LOCK_SHA256=

# --- Firebase Admin (auth token verify + Firestore persist) ---
# CASTLE_REQUIRE_FIREBASE_PERSIST=true iken bu üçü zorunludur
FIREBASE_PROJECT_ID=castle-genesis
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="AIzaSyC5HDBeYGoEfFQW9SDIpCKqmxqNP66fcQE"
CASTLE_REQUIRE_FIREBASE_PERSIST=false

# --- Veri ve mağaza ---
CASTLE_DATA_DIR=apps/gateway/data
CASTLE_STORE_SECRET=
CASTLE_MEMORY_LIMIT=3000
CASTLE_MEMORY_HOT_LIMIT=80
CASTLE_MEMORY_COMPACT_THRESHOLD=220
CASTLE_ACADEMY_EVENT_AUTO_RESOLVE_MS=120000

# Rhizoh LLM isteklerinde bellek/kimlik özeti (maskeli): konsola JSON satırı — üretimde kapalı tutun
# CASTLE_RHIZOH_LLM_DIAG=1
# Tanıda artifact sayımı — istemci VITE_CASTLE_APP_ID ile aynı olmalı (varsayılan castle-vnext-core)
# CASTLE_ARTIFACT_APP_ID=castle-vnext-core

# --- Rhizoh LLM (CASTLE_LLM_PROVIDER ile seçilir) ---
# openai | anthropic | gemini | xai | deepseek | mistral | openrouter
CASTLE_LLM_PROVIDER=openai
CASTLE_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# Voice Engine v3 — POST /rhizoh/voice/transcribe/v3 (Whisper = OPENAI_API_KEY; Google fast = GOOGLE_SPEECH_API_KEY or GOOGLE_API_KEY)
# GOOGLE_SPEECH_API_KEY=
# CASTLE_RL_RHIZOH_VOICE_TRANSCRIBE_PER_MIN=30

# /rhizoh/llm isteklerinde llmKeySource zorunlu olsun (env | user_connection; auto yasak)
# CASTLE_LLM_REQUIRE_EXPLICIT_KEY_SOURCE=1
# Dakika başına limitler (bellek içi; tek süreç)
# CASTLE_RL_RHIZOH_LLM_PER_MIN=40
# CASTLE_RL_LLM_CONNECTION_TEST_PER_MIN=8
# Erişim özeti satırı — CASTLE_LLM_ACCESS_LOG=0 ile kapat
# CASTLE_LLM_ACCESS_LOG=
# θ faz bağlantılı constitutional LLM çıktı filtresi (immune aggression → hedge/kısalt). Kapatmak için:
# CASTLE_CONSTITUTIONAL_THETA_LLM_FILTER=0
# CASTLE_THETA_IMMUNE_MAX_REPLY_CHARS=900
# LLM yanıtından constitutionalThetaStressBump üretimini kapatmak için:
# CASTLE_CONSTITUTIONAL_THETA_LLM_FEEDBACK=0

# Rhizoh ürün policy — dış ground truth (GET /rhizoh/product/external-truth; nüfus kohortu stub)
# RHIZOH_SERVER_HOLDOUT_PCT=15
# RHIZOH_EXTERNAL_TRUTH_TTL_MS=300000
# CASTLE_RL_RHIZOH_EXTERNAL_TRUTH_PER_MIN=120
# RHIZOH_EXTERNAL_TRUTH_REQUIRE_TOKEN=1
# CASTLE_EXTERNAL_TRUTH_SALT=

# İstemci external loss batch (POST /rhizoh/product/external-loss/batch; ring özeti, ham olay kalıcı değil)
# CASTLE_RL_RHIZOH_EXTERNAL_LOSS_BATCH_PER_MIN=48
# RHIZOH_EXTERNAL_LOSS_BATCH_REQUIRE_TOKEN=1

# Ground Truth Bridge — sistem dışı outcome (POST /rhizoh/product/outcome; policy’den bağımsız). Agregasyon MVP bellek içi.
# GET /rhizoh/product/outcome/aggregate?cohortId=&decisionFingerprint=&limit=
# CASTLE_RL_RHIZOH_PRODUCT_OUTCOME_PER_MIN=24
# Aynı subjectKey başına (zehirlenme / flood freni): varsayılan 18/dk
# CASTLE_RL_RHIZOH_PRODUCT_OUTCOME_SUBJECT_PER_MIN=18
# RHIZOH_PRODUCT_OUTCOME_REQUIRE_TOKEN=1
# Truth Integrity — tüm gövde için HMAC-SHA256 (hex), başlık: X-Rhizoh-Outcome-Signature: <hex> veya v1=<hex>
# RHIZOH_PRODUCT_OUTCOME_HMAC_SECRET=
# Kaynak bazlı ingest paylaşılan sır: {"crm":"...","support":"..."} — başlık: X-Rhizoh-Outcome-Source-Token
# RHIZOH_PRODUCT_OUTCOME_SOURCE_TOKENS_JSON={"crm":"replace-me"}

# Rhizoh R1–R4 gateway injection (/rhizoh/llm → result.rhizohProduction). Kapatmak için:
# CASTLE_RHIZOH_PRODUCTION_LAYER=0
# Varsayılan ürün gecikme bütçesi (ms); context.latencyBudgetMs / payload ile ezilebilir
# CASTLE_RHIZOH_LATENCY_BUDGET_MS=2500
# Karar katmanı (R5): reject için yanıtı gateway'de kes — varsayılan kapalı (yalnızca observation + rhizohProduction.decision)
# CASTLE_RHIZOH_DECISION_ENFORCE=1
# CASTLE_RHIZOH_REJECT_FALLBACK_REPLY=

# R6–R7 policy tuning / governance (JSON tek satır; policyVersion zorunlu)
# Aktif paket — thresholds yalnız bilinen R5 anahtarları ile merge edilir
# CASTLE_RHIZOH_GOVERNANCE_POLICY_JSON={"policyVersion":"1.0.1","status":"approved","thresholds":{"maxRelativeCostThrottle":22}}
# Shadow — ikinci kararı hesaplar; kullanıcı yanıtı değiştirmez (shadowDecision karşılaştırma)
# CASTLE_RHIZOH_GOVERNANCE_SHADOW_POLICY_JSON={"policyVersion":"1.0.0-shadow","status":"draft","thresholds":{"minEthicsScoreReject":0.2}}
# Canary — traceId üzerinden deterministik örnekleme; CASTLE_RHIZOH_GOVERNANCE_CANARY_PCT yüzdesi (0–100)
# CASTLE_RHIZOH_GOVERNANCE_CANARY_PCT=0
# CASTLE_RHIZOH_GOVERNANCE_CANARY_POLICY_JSON={"policyVersion":"1.1.0-canary","status":"approved","thresholds":{"maxHarmGradientReject":0.82}}
# Geri bildirim — istek gövdesi constitutionalFeedbackOutcome: positive | negative (R6 öğrenmesi)
# CASTLE_RHIZOH_FEEDBACK_LOG_PATH=apps/gateway/data/rhizoh-feedback.jsonl
# CASTLE_RHIZOH_FEEDBACK_RING_MAX=2000
# Agregasyon + R6 tuning önerileri JSON olarak rhizohProduction.governance.feedbackLearning içinde
# CASTLE_RHIZOH_FEEDBACK_SUMMARY=1

# Operational hardening — gözlemlenebilirlik zarfı rhizohProduction.operational.observability
# CASTLE_DEPLOY_REGION=eu-west
# CASTLE_DEPLOYMENT_NAME=gateway-prod
# Çok-bölge policy özeti (JSON dizi): [{ "regionId":"eu","policyVersion":"1.0.1","priority":10 }]
# CASTLE_RHIZOH_MULTI_REGION_PEERS_JSON=[]
# SHA256 hash-chain denetim günlüğü (append-only); kapatmak için CASTLE_RHIZOH_AUDIT_CHAIN=0
# CASTLE_RHIZOH_AUDIT_CHAIN_PATH=apps/gateway/data/rhizoh-audit-chain.jsonl
# Varsayılan fsync açık — dev için: CASTLE_RHIZOH_AUDIT_FSYNC=0
# Büyük dosya rotasyonu (byte); 0 = kapalı
# CASTLE_RHIZOH_AUDIT_CHAIN_ROTATE_BYTES=104857600
# Birincil zincire ek olarak aynı satırın ikinci diske yazımı (best-effort)
# CASTLE_RHIZOH_AUDIT_MIRROR_PATH=apps/gateway/data/rhizoh-audit-chain.mirror.jsonl
# Rotasyon sonrası segment kopyası — harici WORM/cold tier ingest için (örn. s3 sync cron)
# CASTLE_RHIZOH_AUDIT_ARCHIVE_AFTER_ROTATE_DIR=apps/gateway/data/rhizoh-audit-archive

# Enterprise ölçek — OpenTelemetry (trace), Prometheus (/infra/metrics/prometheus)
# CASTLE_OTEL_ENABLED=1
# OTEL_SERVICE_NAME=castle-gateway
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# veya doğrudan: OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
# Kök trace örnekleme oranı (0–1); üretimde genelde 0.02–0.1
# CASTLE_OTEL_TRACE_SAMPLE_RATE=0.05
# CASTLE_PROMETHEUS_METRICS=1

# Çok-bölge quorum ipucu — JSON dizi: [{ "regionId":"eu-west","stance":"approve","weight":1,"observedAtMs":1735689600000 }]
# CASTLE_RHIZOH_QUORUM_VOTES_JSON=[]
# Gecikme / eski oy politikası (tek JSON veya aşağıdaki env ile merge):
# CASTLE_RHIZOH_QUORUM_LATENCY_POLICY_JSON={"maxVoteAgeMs":120000,"waitCapMs":800,"holdOnStaleExcluded":false}
# CASTLE_RHIZOH_QUORUM_MAX_VOTE_AGE_MS=
# CASTLE_RHIZOH_QUORUM_WAIT_CAP_MS=
# Eskimiş oy varsa öneriyi zorla hold: CASTLE_RHIZOH_QUORUM_HOLD_ON_STALE=1

# --- Sosyal bağlayıcılar (isteğe bağlı) ---
CASTLE_TELEGRAM_BOT_TOKEN=
CASTLE_WHATSAPP_TOKEN=
CASTLE_WHATSAPP_PHONE_NUMBER_ID=
CASTLE_SOCIAL_RETRY_MAX=2
CASTLE_SOCIAL_RETRY_BASE_MS=700

# --- Telemetri / coğrafi sınırlar (sunucu tarafı) ---
CASTLE_GEOFENCE_CENTER_LAT=41.0082
CASTLE_GEOFENCE_CENTER_LON=28.9784
CASTLE_GEOFENCE_RADIUS_M=55000
CASTLE_SPEED_CAP_MPS=35
