# Gateway — kopyala: cp .env.example .env.local
# Üretimde gerçek değerleri barındırıcı ortam değişkenlerinde tutun.

# --- Ağ ve güvenlik ---
CASTLE_GATEWAY_PORT=8090
CASTLE_MAX_MESSAGE_BYTES=32768
# İstemci VITE_GATEWAY_TOKEN ile AYNI gizli dize olmalı
CASTLE_GATEWAY_TOKEN=
CASTLE_ALLOWED_ORIGINS=http://localhost:5173,https://localhost:5173
CASTLE_HTTP_CORS_ORIGIN=http://localhost:5173
CASTLE_REQUIRE_AUTH=false
CASTLE_ALLOW_DEV_ANON=true
CASTLE_ALLOW_DEV_HTTP_UID=true
# Firebase Admin yokken JWT ile doğrulama: güçlü rastgele dize
CASTLE_JWT_SECRET=

# --- Firebase Admin (auth token verify + Firestore persist) ---
# CASTLE_REQUIRE_FIREBASE_PERSIST=true iken bu üçü zorunludur
FIREBASE_PROJECT_ID=castle-genesis
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
CASTLE_REQUIRE_FIREBASE_PERSIST=false

# --- Veri ve mağaza ---
CASTLE_DATA_DIR=apps/gateway/data
CASTLE_STORE_SECRET=
CASTLE_MEMORY_LIMIT=3000
CASTLE_MEMORY_HOT_LIMIT=80
CASTLE_MEMORY_COMPACT_THRESHOLD=220
CASTLE_ACADEMY_EVENT_AUTO_RESOLVE_MS=120000

# --- Rhizoh LLM (CASTLE_LLM_PROVIDER ile seçilir) ---
# openai | anthropic | gemini | xai | deepseek | mistral | openrouter
CASTLE_LLM_PROVIDER=openai
CASTLE_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GEMINI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=

# --- Sosyal bağlayıcılar (isteğe bağlı) ---
CASTLE_TELEGRAM_BOT_TOKEN=
CASTLE_WHATSAPP_TOKEN=
CASTLE_WHATSAPP_PHONE_NUMBER_ID=
CASTLE_SOCIAL_RETRY_MAX=2
CASTLE_SOCIAL_RETRY_BASE_MS=700

# --- Telemetri / coğrafi sınırlar (sunucu tarafı) ---
CASTLE_GEOFENCE_CENTER_LAT=41.0082
CASTLE_GEOFENCE_CENTER_LON=28.9784
CASTLE_GEOFENCE_RADIUS_M=55000
CASTLE_SPEED_CAP_MPS=35
