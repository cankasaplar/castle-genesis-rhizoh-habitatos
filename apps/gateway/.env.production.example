# Gateway — üretim / sahne şablonu (castle-genesis + Rhizoh)
# Kopyala: cp .env.production.example .env   veya barındırıcıda ortam değişkeni olarak yükle.
# Yükleme sırası: .env → .env.local (override)
#
# Firebase Hosting (istemci): https://castle-genesis.web.app
# İstemci bundle VITE_GATEWAY_HTTP bu sürecin dış HTTPS adresini görmeli (örn. Cloud Run URL).

# --- Ağ ve güvenlik ---
# Render/Fly/Railway: platform genelde PORT verir; sunucu önce PORT, sonra CASTLE_GATEWAY_PORT okur.
CASTLE_GATEWAY_PORT=8090
CASTLE_MAX_MESSAGE_BYTES=32768

# İstemci VITE_GATEWAY_TOKEN ile AYNI olmalı (Rhizoh HTTP başlığı veya query).
# Üretimde güçlü rastgele dize kullanın.
CASTLE_GATEWAY_TOKEN=castle_dev_token_2026

# WebSocket köken kontrolü (virgülle liste)
CASTLE_ALLOWED_ORIGINS=https://castle-genesis.web.app,http://localhost:5173

# CORS: tarayıcı tek Allow-Origin alır. Yalnızca Hosting kullanacaksanız:
CASTLE_HTTP_CORS_ORIGIN=https://castle-genesis.web.app
# Yerel 5173’ten de aynı API’ye istek atacaksanız geçici:
# CASTLE_HTTP_CORS_ORIGIN=*
# veya yalnızca geliştirme:
# CASTLE_HTTP_CORS_ORIGIN=http://localhost:5173

CASTLE_REQUIRE_AUTH=false
CASTLE_ALLOW_DEV_ANON=true
CASTLE_ALLOW_DEV_HTTP_UID=true

# Firebase Admin yokken veya ek doğrulama: güçlü rastgele dize
CASTLE_JWT_SECRET=dev_local_secret

# --- Rhizoh LLM (OpenAI) ---
CASTLE_LLM_PROVIDER=openai
# Model adını OpenAI hesabınızda geçerli sürüme göre güncelleyin (ör. gpt-4o, gpt-4o-mini).
# İleride kullanılabilir bir sürüm seçecekseniz dokümantasyondaki tam model id’sini yazın.
CASTLE_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# --- Firebase Admin (auth verify + Firestore; /health/deps içinde firestore bayrağı) ---
FIREBASE_PROJECT_ID=castle-genesis
FIREBASE_CLIENT_EMAIL=
# Servis hesabı JSON’daki private_key (çok satırlı); Firebase Console API key buraya yapıştırma.
FIREBASE_PRIVATE_KEY=
# Üretimde true yapıp servis hesabını doldurun; yoksa kalıcılık modu dosya veya sınırlı olabilir.
CASTLE_REQUIRE_FIREBASE_PERSIST=false

CASTLE_ARTIFACT_APP_ID=castle-vnext-core

# --- Bellek / tanı ---
CASTLE_STORE_SECRET=
CASTLE_DATA_DIR=/var/castle/gateway-data
CASTLE_RHIZOH_LLM_DIAG=0

# --- Opsiyonel ---
CASTLE_TELEGRAM_BOT_TOKEN=
CASTLE_WHATSAPP_TOKEN=
CASTLE_WHATSAPP_PHONE_NUMBER_ID=
