# Gateway — üretim / sahne şablonu (castle-genesis + Rhizoh)
# Kopyala: cp .env.production.example .env   veya barındırıcıda ortam değişkeni olarak yükle.
# Yükleme sırası: .env → .env.local (override)
#
# Firebase Hosting (istemci): https://castle-genesis.web.app
# İstemci bundle VITE_GATEWAY_HTTP bu sürecin dış HTTPS adresini görmeli (örn. Cloud Run URL).
#
# KRİTİK (Observatory): CASTLE_ALLOWED_ORIGINS + CASTLE_HTTP_CORS_ORIGIN boş/yanlış → tarayıcıda SSE/replay “offline”.
# KRİTİK: CASTLE_REQUIRE_AUTH=true iken istemci token yoksa sessiz 401 (EventSource header kısıtı).
# KRİTİK: CASTLE_ALLOW_DEV_* prod’da true → dev bypass; üretim şablonunda false tutun.

# --- Ağ ve güvenlik ---
# Render/Fly/Railway: platform genelde PORT verir; sunucu önce PORT, sonra CASTLE_GATEWAY_PORT okur.
CASTLE_GATEWAY_PORT=8090
CASTLE_MAX_MESSAGE_BYTES=32768

# İstemci VITE_GATEWAY_TOKEN ile AYNI olmalı (Rhizoh HTTP başlığı veya query).
# Üretimde güçlü rastgele dize kullanın.
CASTLE_GATEWAY_TOKEN=castle_dev_token_2026

# WebSocket + HTTP CORS whitelist (virgülle). İkisi de kullanılır: istek Origin bu listede veya CASTLE_HTTP_CORS_ORIGIN ile eşleşirse Allow-Origin echo edilir.
CASTLE_ALLOWED_ORIGINS=https://castle-genesis.web.app,https://castle-genesis.firebaseapp.com,http://localhost:5173

# Varsayılan / ek tek origin (whitelist’e de eklenir). Tam wildcard için tek başına "*" kullanın.
CASTLE_HTTP_CORS_ORIGIN=https://castle-genesis.web.app
# Yerel 5173’ten de aynı API’ye istek atacaksanız geçici:
# CASTLE_HTTP_CORS_ORIGIN=*
# veya yalnızca geliştirme:
# CASTLE_HTTP_CORS_ORIGIN=http://localhost:5173

# Production substrate: identity verifier required (Firebase Admin preferred, or CASTLE_JWT_SECRET).
# CASTLE_GATEWAY_TOKEN = transport gate only (WS ?token=); NOT a substitute for CASTLE_REQUIRE_AUTH.
CASTLE_REQUIRE_AUTH=true
CASTLE_ALLOW_DEV_ANON=false
CASTLE_ALLOW_DEV_HTTP_UID=false

# WAL peer ingress — closes unsigned relay at gateway boundary (default on when NODE_ENV=production).
CASTLE_REQUIRE_WAL_PEER_AUTH=true
CASTLE_REJECT_UNSIGNED_WAL=true

# Secret hygiene (Render panel — never commit real values)
# CASTLE_SECRETS_ROTATED_AT=2026-05-15T00:00:00.000Z
# CASTLE_JWT_SECRET=   # >=24 chars, unique from CASTLE_GATEWAY_TOKEN
# CASTLE_STORE_SECRET= # distinct from gateway token
# CASTLE_EPISTEMIC_SEAL_SECRET= # optional; distinct from transport token

# Substrate metrics on /infra/metrics (default on; set 0 to disable)
# CASTLE_SUBSTRATE_METRICS=1
# CASTLE_OTEL_ENABLED=1
# OTEL_EXPORTER_OTLP_ENDPOINT=https://your-collector:4318
# OTEL_SERVICE_NAME=castle-gateway
# Presence mesh: `false` → only Firebase (or dev uid) for mesh; guests need `X-Castle-Guest-Id` when true.
CASTLE_ALLOW_MESH_GUEST=true

# Firebase Admin yokken veya ek doğrulama: güçlü rastgele dize
CASTLE_JWT_SECRET=dev_local_secret

# --- Rhizoh LLM (OpenAI) ---
CASTLE_LLM_PROVIDER=openai
# Model adını OpenAI hesabınızda geçerli sürüme göre güncelleyin (ör. gpt-4o, gpt-4o-mini).
# İleride kullanılabilir bir sürüm seçecekseniz dokümantasyondaki tam model id’sini yazın.
CASTLE_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# --- Firebase Admin (auth verify + Firestore; /health/deps içinde firestore bayrağı) ---
FIREBASE_PROJECT_ID=castle-genesis
FIREBASE_CLIENT_EMAIL=
# Servis hesabı JSON’daki private_key (çok satırlı); Firebase Console API key buraya yapıştırma.
FIREBASE_PRIVATE_KEY=
# Üretimde true yapıp servis hesabını doldurun; yoksa kalıcılık modu dosya veya sınırlı olabilir.
CASTLE_REQUIRE_FIREBASE_PERSIST=false

CASTLE_ARTIFACT_APP_ID=castle-vnext-core

# --- Bellek / tanı ---
CASTLE_STORE_SECRET=
CASTLE_DATA_DIR=/var/castle/gateway-data
CASTLE_RHIZOH_LLM_DIAG=0
# --- MVP freeze (ilk stabil omurga): aşağıdakiler 0 kalsın; boot/gürültü riski azalır ---
CASTLE_RHIZOH_WS_EMIT_PATCH=0
CASTLE_RHIZOH_SPINE_TRACE=0
CASTLE_RHIZOH_TRACE_SAMPLE=0
# İleride: CASTLE_RHIZOH_SPINE_TRACE=1 veya CASTLE_RHIZOH_TRACE_SAMPLE=0.03 (örneklem)

# --- GCL (fail-closed financial truth — production ZORUNLU) ---
REDIS_URL=redis://127.0.0.1:6379
CASTLE_GCL_REQUIRE_REDIS=1
CASTLE_GCL_ALLOW_MEMORY_FALLBACK=0
CASTLE_LLM_DAILY_SPEND_LIMIT_USD=15
CASTLE_LLM_DAILY_TOKEN_BUDGET=50000
CASTLE_GCL_ENFORCE_DRIFT=1
CASTLE_PHASED_ROLLOUT_TIER=200
CASTLE_PHASED_ROLLOUT_REQUIRE_REDIS=1
CASTLE_PHASED_ROLLOUT_ALLOW_MEMORY_FALLBACK=0
CASTLE_PHASED_ROLLOUT_LEASE_TTL_MS=120000

# --- Opsiyonel ---
CASTLE_TELEGRAM_BOT_TOKEN=
CASTLE_WHATSAPP_TOKEN=
CASTLE_WHATSAPP_PHONE_NUMBER_ID=
